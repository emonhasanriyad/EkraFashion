{
  "entities": {
    "product": {
      "title": "Product",
      "description": "A product for sale in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "stock": { "type": "number" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "description"]
    },
    "admin": {
      "title": "Admin",
      "description": "Admin user record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "customerNote": { "type": "string" },
        "userId": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "customerAddress", "items", "total", "status", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "product",
      "description": "Collection of store products."
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Authorized admin users."
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Customer orders."
    }
  }
}
